# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dev

# Demo data (after migrate): pnpm db:seed
# Login: demo@holiform.app / DemoForm123!

# Auth (JWT + OTP hashing)
JWT_SECRET=change-me-to-a-long-random-string

# Resend (https://resend.com)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=onboarding@yourverifieddomain.com
RESEND_FROM_NAME=HoliForm

# Links in notification emails
WEB_APP_URL=http://localhost:3000

# Inngest — local development (v4 SDK)
# Set to 1 while running `pnpm dev:inngest` alongside the API
INNGEST_DEV=1

# Inngest — production (uncomment when deploying to Inngest Cloud)
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# AI form builder (OpenAI gpt-5.4-mini — https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Web app → API (optional; defaults to http://localhost:8000/trpc)
NEXT_PUBLIC_API_URL=http://localhost:8000/trpc

# Public site URL for OG/canonical links (optional; defaults to WEB_APP_URL or localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API server (Render/Railway)
# PORT=8000
# BASE_URL=https://your-api.onrender.com
# WEB_APP_URL=https://your-app.vercel.app
# NODE_ENV=prod
